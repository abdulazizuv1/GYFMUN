rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public can only CREATE applications (submit form), not read/update/delete.
    // Read, update, delete require a logged-in admin user.
    match /applications/{docId} {
      allow create: if request.resource.data.keys().hasAll([
        'fullName', 'email', 'studyPlace', 'telegram',
        'phone', 'committee', 'munCount', 'consentAccepted', 'submittedAt'
      ])
      && request.resource.data.consentAccepted == true
      && request.resource.data.munCount is int
      && request.resource.data.munCount >= 0;

      allow read, update, delete: if request.auth != null;
    }
  }
}
